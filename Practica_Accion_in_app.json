    {
      "parameters": {
        "jsCode": "// Recuperamos el mensaje original con la sintaxis correcta\nconst mensajeUsuario = $('When chat message received').first().json.chatInput;\n\n// Construimos una respuesta amable de \"No Entendido\"\nconst respuestaFinal = `\n🤔 *¡Hola! No logré detectar un registro.*\n\nRecibí: _\"${mensajeUsuario}\"_\n\nRecuerda que para registrar tus horas debes indicar el **proyecto** y la **cantidad de horas**. \n_Ejemplo: \"Registra 3 horas en el proyecto API de Seguros\"_\n`.trim();\n\nreturn {\n  text: respuestaFinal\n};"
      },
